# SAP Concur API Credentials
CONCUR_CLIENT_ID=your_client_id_here
CONCUR_CLIENT_SECRET=your_client_secret_here

# API Endpoints (default is US datacenter, change if using EMEA/other regions)
CONCUR_TOKEN_URL=https://us.api.concursolutions.com/oauth2/v0/token
CONCUR_BASE_URL=https://us.api.concursolutions.com

# Target User Login ID (usually email address) to test creating the draft report
CONCUR_USER_LOGIN_ID=user@example.com
